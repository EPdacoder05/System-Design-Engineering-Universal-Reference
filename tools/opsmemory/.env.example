# OpsMemory — example environment configuration
#
# Copy this file to .env and fill in the values appropriate for your deployment.
# NEVER commit a populated .env file to version control.
# Use GitHub Actions secrets, AWS Secrets Manager, or similar for CI/CD.

# ---------------------------------------------------------------------------
# Database (required)
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://opsmemory:opsmemory@localhost:5432/opsmemory
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# ---------------------------------------------------------------------------
# GitHub connector (at least one of GITHUB_TOKEN or GITHUB_OWNER is required)
# ---------------------------------------------------------------------------

# Personal access token or fine-grained token with repo read access.
# Required to ingest private repos or to avoid rate limiting on public repos.
# If not set, GITHUB_OWNER must be set explicitly.
GITHUB_TOKEN=

# GitHub username or organisation to enumerate repositories for.
# Optional — if omitted, the connector resolves the owner automatically
# from the authenticated GITHUB_TOKEN via GET /user.
GITHUB_OWNER=

# Comma-separated allowlist of repository names to include (default: all).
GITHUB_INCLUDE_REPOS=

# Comma-separated denylist of repository names to skip.
GITHUB_EXCLUDE_REPOS=

# Seconds between GitHub polling sweeps (default: 3600).
GITHUB_POLL_INTERVAL=3600

# Internal URL the GitHub connector POSTs ingested items to.
OPSMEMORY_INGEST_URL=http://localhost:8000/ingest

# ---------------------------------------------------------------------------
# LLM provider
# ---------------------------------------------------------------------------

# Provider to use for LLM text generation / summarisation.
# Options: "litellm" (real API), "mock" (dev/test, no API calls).
# Default: "mock"
OPSMEMORY_LLM_PROVIDER=mock

# LiteLLM-format model string for the LLM provider.
# Examples:
#   anthropic/claude-3-haiku-20240307    (Anthropic direct — needs ANTHROPIC_API_KEY)
#   anthropic/claude-3-5-sonnet-20241022
#   openai/gpt-4o                        (OpenAI — needs OPENAI_API_KEY)
#   bedrock/anthropic.claude-3-haiku-20240307-v1:0  (AWS Bedrock — needs AWS creds)
OPSMEMORY_LLM_MODEL=anthropic/claude-3-haiku-20240307

# ---------------------------------------------------------------------------
# Embedding provider
# ---------------------------------------------------------------------------

# Provider to use for vector embedding generation.
# Options: "litellm" (real API), "mock" (dev/test, no API calls).
# Default: "mock"
OPSMEMORY_EMBEDDING_PROVIDER=mock

# LiteLLM-format model string for the embedding provider.
# Examples:
#   openai/text-embedding-3-small        (OpenAI — 1536-dim, needs OPENAI_API_KEY)
#   openai/text-embedding-3-large        (3072-dim — update pgvector column too)
#   bedrock/amazon.titan-embed-text-v2:0 (1024-dim — needs AWS creds)
OPSMEMORY_EMBEDDING_MODEL=openai/text-embedding-3-small

# ---------------------------------------------------------------------------
# LiteLLM configuration (only needed when using the litellm provider)
# ---------------------------------------------------------------------------

# Optional: base URL for LiteLLM proxy mode or an OpenAI-compatible backend.
# Leave empty to use LiteLLM SDK mode (direct API calls, no proxy process).
# Example (LiteLLM proxy): http://localhost:4000
# Example (Ollama):        http://localhost:11434
OPSMEMORY_LITELLM_BASE_URL=

# Optional: API key forwarded to LiteLLM.
# For most providers, set the provider-specific key instead (see below).
OPSMEMORY_LITELLM_API_KEY=

# ---------------------------------------------------------------------------
# Provider-specific API keys
# Set only the keys needed for your chosen provider(s).
# LiteLLM reads these automatically.
# ---------------------------------------------------------------------------

# Anthropic (direct API)
ANTHROPIC_API_KEY=

# OpenAI
OPENAI_API_KEY=

# AWS credentials (for Bedrock) — prefer IAM roles in production
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION_NAME=us-east-1

# Cohere
COHERE_API_KEY=

# ---------------------------------------------------------------------------
# FastMCP server
# ---------------------------------------------------------------------------

# Base URL of the running OpsMemory FastAPI service used by MCP tools.
OPSMEMORY_API_URL=http://localhost:8000
