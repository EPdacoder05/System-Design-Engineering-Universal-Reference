# OpsMemory — Jarvis MCP client environment template
#
# Copy this file to .env (or merge into your existing .env) and fill in the
# values appropriate for your Jarvis deployment.
# NEVER commit a populated .env file to version control.

# ---------------------------------------------------------------------------
# OpsMemory API connection
# ---------------------------------------------------------------------------

# Base URL of the running OpsMemory FastAPI service.
# Change to http://opsmemory:8000 when running inside a Docker Compose network.
OPSMEMORY_API_URL=http://localhost:8000

# Bearer token for authenticated API access.
# Required when the OpsMemory server is started with OPSMEMORY_REQUIRE_API_KEY=true.
# Generate a strong random value:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
# Leave empty if auth is disabled (local development only).
OPSMEMORY_API_KEY=

# Optional separate bearer token for MCP tool calls.
# Falls back to OPSMEMORY_API_KEY when not set.
OPSMEMORY_MCP_TOKEN=

# Base URL of the OpsMemory FastMCP SSE server (only needed for SSE transport).
OPSMEMORY_MCP_URL=http://localhost:8100

# ---------------------------------------------------------------------------
# Jarvis client behaviour
# ---------------------------------------------------------------------------

# Maximum number of evidence items to return per memory query.
JARVIS_MEMORY_QUERY_LIMIT=5

# Source type label used when ingesting Jarvis session/task outcomes.
JARVIS_SESSION_SOURCE_TYPE=jarvis_session

# HTTP request timeout in seconds.
OPSMEMORY_REQUEST_TIMEOUT=30

# ---------------------------------------------------------------------------
# Skip live-server examples in CI / unit test runs
# ---------------------------------------------------------------------------
# Set to true to skip examples that require a running OpsMemory instance.
OPSMEMORY_SKIP_LIVE=false
